PORT=3001

# Paths to Python executables in conda environments
SEEDVC_PYTHON=/path/to/miniconda3/envs/seedvc/python
SADTALKER_PYTHON=/path/to/miniconda3/envs/sadtalker/python

# Paths to cloned model repos (sibling directories by default)
SEEDVC_DIR=/path/to/seed-vc
SADTALKER_DIR=/path/to/sadtalker

# FFmpeg binary directory
FFMPEG_BIN=/path/to/ffmpeg/bin

# Pipeline working directories
UPLOADS_DIR=/path/to/pipeline/uploads
OUTPUTS_DIR=/path/to/pipeline/outputs
